{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "sleepApplication": true,
    "healthCheckPath": "/",
    "RestartPolicy": {
      "type": "ON_FAILURE",
      "maxRetries": 3
    }
  }
}
